# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class

# Build and packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test and coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# Jupyter and local notebooks
.ipynb_checkpoints/

# IDE and editor files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Environment and secrets
.env
.env.*
!.env.example

# Logs
*.log

# Local outputs and generated artifacts
outputs/runs/*
outputs/reports/*
outputs/exports/*

# Keep directory structure
!outputs/runs/.gitkeep
!outputs/reports/.gitkeep
!outputs/exports/.gitkeep

# Temporary files
tmp/
temp/
*.tmp

# Auxiliary documentation bundles that should not be versioned
docs/agro_do_bootstrap_docs.zip
docs/agro_do_bootstrap_docs_updated.zip